<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base App Theme — Dark, No Action Bar -->
    <style name="Theme.LexGuardAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryDark">@color/accent_blue_dark</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Theme — Fullscreen, no system bars -->
    <style name="Theme.LexGuardAI.Splash" parent="Theme.LexGuardAI">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

</resources>
